{
	"name": "polaris-web-components-mcp",
	"version": "1.0.0",
	"description": "MCP server for Shopify Polaris Web Components documentation",
	"module": "src/index.ts",
	"type": "module",
	"license": "MIT",
	"bin": {
		"polaris-web-components-mcp": "dist/index.js"
	},
